{
  "name": "subscription-manager",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev:mobile": "dotenv -e .env -- pnpm --filter mobile start",
    "dev:web": "dotenv -e .env -- pnpm --filter mobile web",
    "dev:api": "dotenv -e .env -- pnpm --filter api dev",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm --filter api build"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
